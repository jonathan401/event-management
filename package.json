{
  "name": "event-management",
  "version": "1.0.0",
  "description": "An event management API",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "jest",
    "build": "tsc",
    "dev": "nodemon --exec tsx src/index.ts",
    "prepare": "husky",
    "lint": "eslint . --max-warnings=0 && tsc --noEmit && tsc",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"{src,test}/**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"{src,test}/**/*.{ts,js,json,md}\"",
    "docker:run-build": "docker-compose up --build",
    "docker:build": "docker-compose build",
    "docker:run": "docker compose up -d postgres && docker compose up api",
    "docker:stop": "docker-compose down",
    "typeorm": "npm run build && npx typeorm -d dist/data-source.js",
    "migration:generate": "POSTGRES_HOST=localhost npm run typeorm -- migration:generate",
    "migration:run": "POSTGRES_HOST=localhost npm run typeorm -- migration:run",
    "migration:revert": "POSTGRES_HOST=localhost npm run typeorm -- migration:revert"
  },
  "author": "Jonathan",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/compat": "^1.4.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.38.0",
    "@testcontainers/postgresql": "^11.11.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.4",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.38.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^61.0.2",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "prisma": "^7.3.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "typescript-eslint": "^8.46.2",
    "winston": "^3.18.3"
  }
}
