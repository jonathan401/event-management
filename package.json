{
  "name": "event-management",
  "version": "1.0.0",
  "description": "An event management API",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "jest",
    "build": "tsc",
    "dev": "nodemon --exec tsx src/index.ts",
    "docker": "docker compose up -d mongodb && docker compose up api",
    "prepare": "husky",
    "lint": "eslint . --max-warnings=0 && tsc --noEmit && tsc --noEmit -p test/tsconfig.json",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"{src,test}/**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"{src,test}/**/*.{ts,js,json,md}\""
  },
  "author": "Jonathan",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/compat": "^1.4.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.38.0",
    "@testcontainers/mongodb": "^11.9.0",
    "@types/express": "^5.0.4",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.38.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^61.0.2",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-validator": "^7.3.0",
    "mongoose": "^8.19.2",
    "typescript-eslint": "^8.46.2",
    "winston": "^3.18.3"
  }
}